{:paths ["src" "test"]
 :deps {io.github.kotoba-lang/org-ietf-ed25519  {:local/root "../org-ietf-ed25519"}
        io.github.kotoba-lang/org-ietf-cbor {:local/root "../org-ietf-cbor"}}
 :tasks
 {kotoba
  {:doc "DID / CACAO / seed identity-primitives CLI. `bb kotoba help` for usage."
   :requires ([cacao.cli :as cli])
   :task (apply cli/-main *command-line-args*)}
  test
  {:task (do (require 'clojure.test 'cacao.core-test 'cacao.cli-test)
             (let [r (clojure.test/run-tests 'cacao.core-test 'cacao.cli-test)]
               (when (pos? (+ (:fail r) (:error r))) (System/exit 1))))}}}
